# === Chatbot service (GĐ2) — sao chép thành .env ===

# --- shop_api (chatbot gọi như client public, giống FE web) ---
SHOP_API_BASE_URL=http://127.0.0.1:5000/api/v1

# --- LLM router (OpenAI-compatible). Bỏ trống -> dùng FakeLLM (chạy offline) ---
# Đổi provider = đổi 2 dòng này (adapter §6.3). Production hướng Bedrock/Azure Tokyo (Q7).
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# --- Session store. Bỏ trống REDIS_URL -> in-memory (dev/MVP, Q5) ---
REDIS_URL=
SESSION_TTL_SECONDS=1800

# --- App-level encryption cho field vault trong session (Q5). Bỏ trống = không mã hóa
#     (chấp nhận ở MVP in-memory; bật khi lưu Redis/production — 7.1) ---
VAULT_ENC_KEY=

# Cửa hàng để lấy số điện thoại handoff khi chưa chọn shop (MVP).
FALLBACK_SHOP_PHONE=0779776153
